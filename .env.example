AQUARIUM_DEFAULT_LOCALE=ko
AQUARIUM_DATA_DIR=/data
POSTGRES_DB=aquarium
POSTGRES_USER=aquarium
POSTGRES_PASSWORD=aquarium

# Adapter commands. Leave blank to run explicit local_stub/degraded mode.
# Commands receive AQUARIUM_TOPIC, AQUARIUM_LOCALE, AQUARIUM_MODE, AQUARIUM_RUN_DIR.
# MiroFish also receives AQUARIUM_HANDOFF_MANIFEST.
# Example sibling local commands after the runner support is available in each repo:
# AQUARIUM_BETTAFISH_COMMAND="python3 /Users/crimson/Projects/bettafish-localized/scripts/bettafish_aquarium_runner.py"
# AQUARIUM_MIROFISH_COMMAND="python3 /Users/crimson/Projects/mirofish-localized/scripts/mirofish_aquarium_runner.py"
AQUARIUM_BETTAFISH_COMMAND=
AQUARIUM_MIROFISH_COMMAND=
AQUARIUM_ADAPTER_TIMEOUT_SECONDS=1800
# Optional comma-separated extra env names to pass to runner subprocesses.
# Defaults are intentionally narrow so unrelated secrets are not leaked.
AQUARIUM_RUNNER_ENV_ALLOWLIST=

# One-command local canary overrides. The canary fails non-zero unless both stages are real completed.
AQUARIUM_CANARY_TOPIC=AI 검색엔진과 로컬 보고서 자동화 시장 동향
AQUARIUM_CANARY_LOCALE=ko
AQUARIUM_CANARY_MODE=single
AQUARIUM_CANARY_DATA_DIR=.hermes/runs/real-integration-canary/data

# Future real-provider endpoints
SEARXNG_BASE_URL=http://searxng:8080
GRAPHITI_BASE_URL=http://graphiti:8000
OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:10531/v1
OPENAI_COMPATIBLE_MODEL=gpt-5.5
